# Absolute path on the server where generated quote PDFs are written.
# Local dev default: ./.quote-storage
# Railway: mount a persistent volume and point here (e.g. /data/quotes)
QUOTE_STORAGE_DIR="./.quote-storage"

# HubSpot integration (Phase 1+)
# Primary: client-credentials grant from a Developer Project app
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
HUBSPOT_PORTAL_ID=
# Optional: space-separated scope override (defaults to the 8 Phase 1 scopes)
# HUBSPOT_SCOPES="crm.objects.products.read crm.objects.products.write ..."
# Emergency override / classic private app fallback — skip the token exchange
# HUBSPOT_ACCESS_TOKEN=

# Phase 3 — App Card
# The App Card reuses HUBSPOT_ACCESS_TOKEN (already set from earlier phases) as the bearer
# credential for /api/hubspot/card/* endpoints. HubSpot auto-injects the same token into App
# Functions as PRIVATE_APP_ACCESS_TOKEN — no separate shared secret or CLI secret setup required.
# Optional — override the pricer's production URL (default: https://ninjapricer-production.up.railway.app)
PRICER_APP_URL=
# Optional — attribute scenarios created from the App Card to a specific user.
HUBSPOT_CARD_SERVICE_USER_EMAIL=
